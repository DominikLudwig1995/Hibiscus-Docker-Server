# Copy to .env and fill in your values — never commit .env to git.
#
#   cp .env.example .env
#   docker compose up -d

# ── Required ──────────────────────────────────────────────────────────────────

# Hibiscus master password (unlocks the keystore)
HIBISCUS_PASSWORD=changeme

# Database credentials (shared between the postgres and hibiscus services)
DB_USERNAME=hibiscus
DB_PASSWORD=changeme

# ── Optional ──────────────────────────────────────────────────────────────────

# Database name (default: hibiscus)
# DB_NAME=hibiscus

# Hibiscus web interface port on the host (default: 8888)
# HIBISCUS_PORT=8888

# Disable auth or SSL for local dev (not recommended in production)
# HIBISCUS_HTTP_AUTH=false
# HIBISCUS_HTTP_SSL=false

# Persistent Jameica data directory on the host (default: ./data/jameica)
# JAMEICA_DATA_PATH=/opt/hibiscus/data
